rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────

    // Bootstrap admins (hardcoded). These accounts always have admin access
    // even before /config/main exists.
    function isHardcodedAdmin() {
      return request.auth != null && request.auth.token.email in [
        'phuc.lnk@cyberlogitec.com',
        'anhhao.dl108@gmail.com'
      ];
    }

    // Dynamic admins from /config/main.adminEmails (added by another admin).
    function isConfigAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/config/main)
        && request.auth.token.email in
             get(/databases/$(database)/documents/config/main).data.get('adminEmails', []);
    }

    function isAdmin() {
      return isHardcodedAdmin() || isConfigAdmin();
    }

    // Server-side enrollment-open check (deadline + allowEnrollment).
    // Uses request.time (server timestamp) so users cannot bypass by clock change.
    function isEnrollmentOpen() {
      return !exists(/databases/$(database)/documents/config/main)
        || isEnrollmentOpenInner();
    }
    function isEnrollmentOpenInner() {
      let cfg = get(/databases/$(database)/documents/config/main).data;
      let allowEnroll = cfg.get('allowEnrollment', true);
      let deadline = cfg.get('deadline', null);
      return allowEnroll != false
        && (deadline == null || request.time < deadline);
    }

    // Block-list check: if /ineligibility/{empCode} exists, the user
    // with that empCode is denied from creating/updating their registration.
    // The empCode comes from the registration payload (request.resource.data),
    // not from the auth token (Firestore doesn't know each user's empCode).
    // Empty /ineligibility collection = nobody blocked (default).
    function isNotBlocked() {
      return request.resource.data.empCode is string
        && !exists(/databases/$(database)/documents/ineligibility/$(request.resource.data.empCode));
    }

    // EmpCode uniqueness lock. The app writes /empCodeClaims/{empCode}
    // in the same transaction as /registrations/{email}; getAfter() validates
    // the post-commit owner so a registration cannot bypass the claim doc.
    function hasOwnEmpCodeClaim() {
      return request.resource.data.empCode is string
        && getAfter(/databases/$(database)/documents/empCodeClaims/$(request.resource.data.empCode)).data.email
           == request.auth.token.email;
    }

    function validOwnEmpCodeClaim(empCode) {
      return request.resource.data.keys().hasOnly(['email'])
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && empCode.matches('^[0-9]{6}$');
    }

    function validClaimForExistingRegistration(empCode) {
      return request.resource.data.keys().hasOnly(['email'])
        && request.resource.data.email is string
        && empCode.matches('^[0-9]{6}$')
        && exists(/databases/$(database)/documents/registrations/$(request.resource.data.email))
        && get(/databases/$(database)/documents/registrations/$(request.resource.data.email)).data.empCode == empCode;
    }

    // Slot update by non-admin: only `remaining` field can change,
    // and it must stay within [0, capacity].
    function onlyRemainingChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['remaining'])
        && request.resource.data.remaining is int
        && request.resource.data.remaining >= 0
        && request.resource.data.remaining <= resource.data.capacity
        // Defense-in-depth: a legit booking/cancel changes `remaining` by exactly ±1
        // (verified in db.ts: decrement on book, increment on release/cancel). This
        // blocks a malicious client from jumping `remaining` up to capacity in a
        // single write to manufacture free seats. Residual risk: looped ±1 writes
        // (slower, detectable, still bounded by [0, capacity]) — a full fix needs a
        // server-authoritative counter (Cloud Function), which breaks client-only.
        && (request.resource.data.remaining == resource.data.remaining + 1
            || request.resource.data.remaining == resource.data.remaining - 1);
    }

    // Validation for new slot (admin create).
    function validNewSlot() {
      return request.resource.data.type in ['Speaking', '3 Skills']
        && request.resource.data.capacity is int
        && request.resource.data.capacity > 0
        && request.resource.data.startMin is int
        && request.resource.data.startMin >= 0
        && request.resource.data.endMin is int
        && request.resource.data.endMin > request.resource.data.startMin
        && request.resource.data.remaining is int
        && request.resource.data.remaining >= 0
        && request.resource.data.remaining <= request.resource.data.capacity;
    }

    // Validation for admin slot updates: per-field guards that only fire
    // when that specific field is changing. Unchanged fields skip their
    // check. `remaining` is always validated (must stay in [0, capacity]).
    function validAdminSlotUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.remaining is int
        && request.resource.data.remaining >= 0
        && request.resource.data.remaining <= request.resource.data.capacity
        && (!changed.hasAny(['type'])
            || request.resource.data.type in ['Speaking', '3 Skills'])
        && (!changed.hasAny(['capacity'])
            || (request.resource.data.capacity is int
                && request.resource.data.capacity > 0))
        && (!changed.hasAny(['startMin'])
            || (request.resource.data.startMin is int
                && request.resource.data.startMin >= 0))
        && (!changed.hasAny(['endMin'])
            || (request.resource.data.endMin is int
                && request.resource.data.endMin > request.resource.data.startMin));
    }

    // ─── Slots ──────────────────────────────────────────────────────────
    // Read: any signed-in user
    // Create: admin only, with field validation
    // Update: admin (validated fields) OR signed-in user (ONLY `remaining` for booking tx)
    // Delete: admin only
    match /slots/{slotId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() && validNewSlot();
      allow update: if (isAdmin() && validAdminSlotUpdate())
                    || (request.auth != null && onlyRemainingChanged());
      allow delete: if isAdmin();
    }

    // ─── Config ─────────────────────────────────────────────────────────
    // Read: any signed-in user (for deadline pill, enrollment status)
    // Write: admin only
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── Registrations ──────────────────────────────────────────────────
    // Read/Write own: signed-in user, with server-side deadline + blocklist check
    // Admin: full access (bypass deadline so admin can fix things after deadline)
    match /registrations/{email} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.token.email == email);

      allow create: if isAdmin()
        || (request.auth != null
            && request.auth.token.email == email
            && isEnrollmentOpen()
            && isNotBlocked()
            && hasOwnEmpCodeClaim());

      allow update: if isAdmin()
        || (request.auth != null
            && request.auth.token.email == email
            && isEnrollmentOpen()
            && isNotBlocked()
            && hasOwnEmpCodeClaim());

      allow delete: if isAdmin()
        || (request.auth != null
            && request.auth.token.email == email
            && isEnrollmentOpen());
    }

    // ─── EmpCode Claims (one empCode = one active registration) ─────────
    // Key = empCode. Doc shape: { email }
    // Read: single-doc reads allowed for signed-in users so bookDb can detect
    // an existing claim in its transaction; list remains admin-only.
    // Write/delete: owner-scoped, so users cannot steal or release another
    // email's empCode claim. Admin bypasses this for production data fixes.
    match /empCodeClaims/{empCode} {
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow create: if isAdmin()
        || (request.auth != null
            && (validOwnEmpCodeClaim(empCode) || validClaimForExistingRegistration(empCode)));
      allow update: if isAdmin()
        || (request.auth != null
            && resource.data.email == request.auth.token.email
            && validOwnEmpCodeClaim(empCode));
      allow delete: if isAdmin()
        || (request.auth != null
            && resource.data.email == request.auth.token.email);
    }

    // ─── Eligibility (allowlist by empCode) ──────────────────────────────
    // Key = empCode (6 digits). Doc shape: { empCode, fullName, bu?, email? }
    // Read: `get` (single doc by empCode) allowed for any signed-in user
    //       so they can check their own eligibility. `list` requires admin
    //       to prevent scraping the full allowlist.
    // Write: admin only.
    match /eligibility/{empCode} {
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── Ineligibility (blocklist by empCode with reason) ───────────────
    // Key = empCode (6 digits). Doc shape: { reason, fullName?, email? }
    //
    // Read: `get` (single doc by empCode) allowed for any signed-in user
    //       so they can pre-flight check their own status after typing
    //       empCode. `list` (enumerate collection) requires admin so users
    //       cannot scrape the full blocklist.
    // Write: admin only.
    match /ineligibility/{empCode} {
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── Audit Logs (immutable) ─────────────────────────────────────────
    // Read: admin only
    // Create: any signed-in user (own actions)
    // Update/Delete: nobody (immutable)
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.email is string
        && request.resource.data.event is string;
      allow update, delete: if false;
    }

    // ─── Cancelled Quota (quota preserved across cancel+re-register) ─────
    // Written by cancelDb, read+deleted by bookDb. Owner-scoped only.
    match /cancelledQuota/{email} {
      allow read, write: if request.auth != null && request.auth.token.email == email;
    }

    // ─── Mail (Firebase Send-Email extension queue) ─────────────────────
    // Read: admin only
    // Create: any signed-in user (confirmation emails written from booking)
    // Update/Delete: extension manages
    match /mail/{id} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
