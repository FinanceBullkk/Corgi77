{
  "name": "assessment-booking-q2-2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "npm run typecheck && npm test -- --run && npm run check:functions && npm run build",
    "check:functions": "node --check functions/index.js",
    "check:rules": "FIREBASE_CLI_DISABLE_UPDATE_NOTIFIER=true firebase deploy --only firestore:rules --project corgi7-d129d --dry-run",
    "test:rules": "XDG_CONFIG_HOME=.firebase/local-config FIREBASE_CLI_DISABLE_UPDATE_NOTIFIER=true firebase emulators:exec --project demo-corgi7-rules --only firestore \"npm run test:rules:vitest\"",
    "test:rules:vitest": "vitest run src/__tests__/firestore-rules.emulator.test.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sentry/react": "^10.55.0",
    "firebase": "^12.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "firebase-tools": "^15.19.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.7"
  }
}
